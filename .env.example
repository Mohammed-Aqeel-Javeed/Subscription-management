# Environment variables for SubscriptionTracker
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_DB=Subtrackerr

# Security Keys - CRITICAL: Keep these secret!
# Generate new keys by running: npm run generate-keys
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Platform Owner (Global Admin) Login
# Use these credentials on the normal login page; you will be redirected to /platform-admin
PLATFORM_OWNER_EMAILS=admin@yourdomain.com
PLATFORM_OWNER_PASSWORD=your_strong_password_or_bcrypt_hash

# Optional: force TLS for Mongo (only needed for some mongodb:// URIs)
MONGODB_TLS=false

# SMTP Configuration for Email Sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Stripe (required for Platform Billing pages)
# If not set, Billing/Subscriptions/Payments/Invoices will show "Stripe is not configured".
STRIPE_SECRET_KEY=sk_test_or_sk_live_here

# Optional: used when creating/upgrading subscriptions
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...

# Environment (development or production)
NODE_ENV=development

# Google OAuth (used by /api/auth/google/start)
# Create OAuth Client ID (Web application) in Google Cloud Console.
# Authorized redirect URIs must include:
#   - Local:  http://localhost:5000/api/auth/google/callback
#   - Render: https://subscription-management-6uje.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional: external/public base URL used to build the OAuth redirect URI.
# If omitted, Render uses RENDER_EXTERNAL_URL automatically; otherwise the server infers from request headers.
# PUBLIC_BASE_URL=http://localhost:5000

# Optional: used for redirects after OAuth/Stripe when frontend is hosted separately.
# Leave empty for same-domain deployment.
# FRONTEND_URL=http://localhost:5173
