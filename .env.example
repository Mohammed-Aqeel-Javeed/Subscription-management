# Environment variables for SubscriptionTracker
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_DB=Subtrackerr

# Security Keys - CRITICAL: Keep these secret!
# Generate new keys by running: npm run generate-keys
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Platform Owner (Global Admin) Login
# Use these credentials on the normal login page; you will be redirected to /platform-admin
PLATFORM_OWNER_EMAILS=admin@yourdomain.com
PLATFORM_OWNER_PASSWORD=your_strong_password_or_bcrypt_hash

# Optional: force TLS for Mongo (only needed for some mongodb:// URIs)
MONGODB_TLS=false

# SMTP Configuration for Email Sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Environment (development or production)
NODE_ENV=development
